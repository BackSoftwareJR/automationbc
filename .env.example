# Copy to .env and fill in real values.
BRIDGE_API_KEY=change-me-to-a-long-random-secret
GITHUB_TOKEN=

# Required: n8n webhook URL to POST results after agent finishes
N8N_CALLBACK_URL=https://your-n8n-instance.com/webhook/cursor-result
CALLBACK_TIMEOUT_SEC=30
CALLBACK_MAX_ATTEMPTS=5
CALLBACK_RETRY_DELAY_SEC=5
CALLBACK_SUMMARY_MAX_CHARS=15000

# --- Windows ---
# FastAPI bridge runs natively on Windows (Python + uvicorn).
# Cursor CLI "agent" on Windows: either native install OR via WSL.

# Native Windows install (PowerShell):
#   irm 'https://cursor.com/install?win32=true' | iex
# Then verify: agent --version

# OR run agent inside WSL (recommended if native agent fails):
#   AGENT_USE_WSL=true
#   WSL_DISTRO=Ubuntu
AGENT_USE_WSL=true
WSL_DISTRO=Ubuntu

# Cursor CLI binary name (inside WSL or native PATH)
AGENT_BIN=agent

# Optional: passed to agent subprocess (or use `agent login`)
CURSOR_API_KEY=

# Workspace paths (Windows paths are OK, e.g. C:\Users\ACER\Desktop\main-bs-web)
DEFAULT_WORKSPACE=..

# project_area "bs-webdev" -> WORKSPACE_BS_WEBDEV
WORKSPACE_BS_WEBDEV=..

# Wall-clock kill for a single agent run (0 = disabled — recommended for long tasks).
AGENT_TIMEOUT_SEC=0
# POST status=progress to N8N_CALLBACK_URL while the agent runs (0 = disabled).
AGENT_PROGRESS_CALLBACK_SEC=120
# Kill agent if no stdout/stderr for this many seconds (0 = disabled).
# Ignored when AGENT_OUTPUT_FORMAT is json or stream-json (long tool runs can be silent).
AGENT_IDLE_TIMEOUT_SEC=180
AGENT_OUTPUT_FORMAT=stream-json
AGENT_MAX_ATTEMPTS=5
AGENT_RETRY_DELAY_BEFORE_FINAL_SEC=60
AGENT_WORKER_THREADS=4
# Optional hard cap for watchdog (0 = disabled when AGENT_TIMEOUT_SEC=0).
TASK_MAX_RUNTIME_SEC=0
TASK_WATCHDOG_GRACE_SEC=120

# GitHub HTTPS push without interactive login (PAT with repo scope)
GITHUB_TOKEN=

# n8n target_branch is optional; bridge auto-picks staging (HTML) or main (Node.js/package.json)

# Author for automated git commit (bridge + agent in WSL)
GIT_COMMIT_USER_NAME=Backclub Bridge
GIT_COMMIT_USER_EMAIL=bridge@users.noreply.github.com

DASHBOARD_ALLOW_REMOTE=false
DASHBOARD_LOG_BUFFER_LINES=500
DASHBOARD_MAX_HISTORY=200

LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8787
